# VIA — Viabilidad Inteligente Agrícola
# Copia este archivo como .env y completa los valores reales.

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://via_user:via_password@localhost:5433/via_dev

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
LLM_DRAFTING_PROVIDER=tavily_rag           # tavily_rag | openai_file_search | openai_web_search | none

OPENAI_API_KEY=sk-proj-...
OPENAI_RAG_MODEL=gpt-4o-mini
OPENAI_FILE_SEARCH_MAX_RESULTS=15
OPENAI_FILE_SEARCH_PROMPT_VERSION=via-rag-v1
LLM_TIMEOUT_SECONDS=120

# Web Search experimental (solo cuando LLM_DRAFTING_PROVIDER=openai_web_search)
# OPENAI_WEB_SEARCH_ENABLED=true
# OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium    # low | medium | high
# OPENAI_WEB_SEARCH_ALLOWED_DOMAINS=midagri.gob.pe,senasa.gob.pe,inia.gob.pe,senamhi.gob.pe,fao.org
# OPENAI_WEB_SEARCH_COUNTRY=PE
# OPENAI_WEB_SEARCH_REGION=Lima

# ── Tavily RAG (LLM_DRAFTING_PROVIDER=tavily_rag) ─────────────────────────────
# Filtrado de dominios DURO (server-side), a diferencia de openai_web_search.
# Comparte OPENAI_API_KEY / OPENAI_RAG_MODEL con los otros providers OpenAI.
TAVILY_API_KEY=tvly-...                    # obligatorio; free tier 1 000 búsquedas/mes
# TAVILY_MAX_RESULTS=5
# TAVILY_SEARCH_DEPTH=advanced             # basic | advanced

# Jina Reader (segundo paso para leer PDFs completos encontrados por Tavily)
JINAREADER_ENABLED=true
# JINA_READER_API_KEY=jina_...             # opcional; mejora límites de tasa
# JINA_READER_MAX_URLS=3                   # cuántas URLs se leen en el segundo paso
# JINA_READER_TIMEOUT_SECONDS=25
# JINA_READER_MAX_CHARS_PER_DOC=8000
# JINA_READER_MIN_CHARS=300

# Vector stores de OpenAI (uno por cultivo)
VIA_VECTOR_STORE_MAIZ_AMARILLO_DURO_ID=vs_...
VIA_VECTOR_STORE_MANDARINA_MURCOTT_ID=vs_...
VIA_VECTOR_STORE_MARACUYA_CRIOLLA_AMARILLA_ID=vs_...
VIA_VECTOR_STORE_PALTA_HASS_ID=vs_...
VIA_VECTOR_STORE_UVA_DE_MESA_SWEET_GLOBE_ID=vs_...

# ── Google Earth Engine ────────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT=...@...iam.gserviceaccount.com
GEE_KEY_FILE=path/to/service_account_key.json

# ── Seguridad ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia-esto-en-produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── MCDA Fuzzy ────────────────────────────────────────────────────────────────
MCDA_ALPHA=0.5
