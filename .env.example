# VIA — Viabilidad Inteligente Agrícola
# Copia este archivo como .env y completa los valores reales.

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://via_user:via_password@localhost:5433/via_dev

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
LLM_DRAFTING_PROVIDER=openai_file_search   # o "none" para deshabilitar

OPENAI_API_KEY=sk-proj-...
OPENAI_RAG_MODEL=gpt-4o-mini
OPENAI_FILE_SEARCH_MAX_RESULTS=15
OPENAI_FILE_SEARCH_PROMPT_VERSION=via-rag-v1
LLM_TIMEOUT_SECONDS=120

# Vector stores de OpenAI (uno por cultivo)
VIA_VECTOR_STORE_MAIZ_AMARILLO_DURO_ID=vs_...
VIA_VECTOR_STORE_MANDARINA_MURCOTT_ID=vs_...
VIA_VECTOR_STORE_MARACUYA_CRIOLLA_AMARILLA_ID=vs_...
VIA_VECTOR_STORE_PALTA_HASS_ID=vs_...
VIA_VECTOR_STORE_UVA_DE_MESA_SWEET_GLOBE_ID=vs_...

# ── Google Earth Engine ────────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT=...@...iam.gserviceaccount.com
GEE_KEY_FILE=path/to/service_account_key.json

# ── Seguridad ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia-esto-en-produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── MCDA Fuzzy ────────────────────────────────────────────────────────────────
MCDA_ALPHA=0.5
